# Copy this file to ".env" and fill in your values. NEVER commit ".env".
#   cp .env.example .env    (macOS / Linux)
#   copy .env.example .env  (Windows)

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────
# On the Google account: enable 2-Step Verification, then create an App Password
# (Google Account > Security > App passwords). Paste that 16-char password below.
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
TO_EMAIL=youraddress@gmail.com

# ── Adzuna (free) ──  https://developer.adzuna.com/  ──────────────────────
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Jooble (free) ──  https://jooble.org/api/about  ───────────────────────
JOOBLE_KEY=

# ── Optional ───────────────────────────────────────────────────────────────
# Groq (free) for a one-line "why it fits" per top job:  https://console.groq.com
GROQ_API_KEY=
# SerpApi (free 250/mo) Google Jobs:  https://serpapi.com/
SERPAPI_KEY=

# ── Web UI (optional) ──────────────────────────────────────────────────────
# Override the bind address/port for `python app.py`. Defaults come from
# config.yaml (web.host / web.port). Environment vars take precedence.
# JOBSCOUT_HOST=127.0.0.1
# JOBSCOUT_PORT=8000
